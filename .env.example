# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  REQUIRED — you need both of these to run the app locally               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# PostgreSQL connection string
# Local Docker: postgresql://postgres:postgres@localhost:5432/learning_app
# Neon: postgresql://neondb_owner:<pw>@<host>/neondb?sslmode=require
DATABASE_URL=

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=

# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  OPTIONAL — everything below is only needed for specific features       ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ─── Authentication (WorkOS) ─────────────────────────────────────────────────
# Leave all WORKOS_* vars blank for local mode (no login, single user).
# Set them to enable multi-user auth. See docs/deployment.md for setup.

WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=       # 32+ char random string: openssl rand -base64 32
WORKOS_REDIRECT_URI=          # Dev: http://localhost:3001/api/auth/callback

# ─── Dev bypass token ────────────────────────────────────────────────────────
# Lets agents (e.g. Claude Code) hit the API via Authorization: Bearer <token>
# while WorkOS stays active for browsers. Ignored in production.
DEV_BYPASS_TOKEN=             # Generate: openssl rand -hex 16

# ─── Neon ────────────────────────────────────────────────────────────────────
# Only needed for the db:reset-dev script (resets Neon dev branch to parent).
NEON_PROJECT_ID=              # From: neonctl projects list

# ─── Production ──────────────────────────────────────────────────────────────
APP_URL=                      # Your production URL, used for CORS origin

# ─── Sentry (error tracking) ────────────────────────────────────────────────
# All Sentry vars are opt-in. Leave blank to run without error tracking.
# Note: VITE_SENTRY_DSN is visible in the browser bundle. This is by design
# (Sentry DSNs only allow sending events, not reading them).

SENTRY_DSN=                   # Backend DSN (sentry.io > Project Settings > Client Keys)
VITE_SENTRY_DSN=              # Frontend DSN (same value, VITE_ prefix required by Vite)
SENTRY_AUTH_TOKEN=            # For source map uploads (sentry.io > Settings > Auth Tokens)
SENTRY_ORG=                   # Your Sentry org slug
SENTRY_PROJECT=               # Your Sentry project slug
